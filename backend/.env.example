# =============================================================
#  Crystal Trade Hub — Backend environment
# =============================================================

# Server
PORT=4000
NODE_ENV=development

# Where the user-frontend and admin panel run (for CORS).
# Add as comma-separated list.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:5174

# Database (SQLite by default — zero install)
DATABASE_URL="file:./dev.db"

# To switch to PostgreSQL:
#   1. In prisma/schema.prisma change `provider = "postgresql"`
#   2. DATABASE_URL="postgresql://user:password@localhost:5432/crystal_trade_hub"
# To switch to MySQL:
#   1. provider = "mysql"
#   2. DATABASE_URL="mysql://user:password@localhost:3306/crystal_trade_hub"

# JWT (CHANGE THESE FOR PRODUCTION!)
JWT_SECRET=super-secret-change-me-in-production-please
JWT_EXPIRES_IN=7d
JWT_ADMIN_SECRET=admin-super-secret-also-change-me
JWT_ADMIN_EXPIRES_IN=1d

# Default admin credentials (used by `npm run db:seed`)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@crystaltradehub.local
SEED_ADMIN_PASSWORD=Admin@12345

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10
